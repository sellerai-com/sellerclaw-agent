# Copy to secrets.env in this directory (gitignored) for local Docker Compose and CLI.
# Do not commit real values.
#
# Incoming control-plane Bearer for port 8001 (optional: if unset, a key is auto-generated under data/).
# SELLERCLAW_LOCAL_API_KEY=
#
# Outgoing cloud token override (optional; normally set after sign-in via agent_token.json).
# AGENT_API_KEY=

# Default environment for sellerclaw-agent Docker stack.
# Copy this file or create .env.local / .env.staging / .env.production
# and pass via: ./setup.sh --env staging  (or AGENT_ENV=staging ./setup.sh)
#
# See docs/cli.md for details.

# SellerClaw cloud API that the agent server talks to
SELLERCLAW_API_URL=http://host.docker.internal:8000

# Host port the agent server is exposed on
AGENT_PORT=8001

# Base URL of the UI that hosts /auth/device verification page (dev-admin UI on 5173)
AGENT_VERIFICATION_BASE_URL=http://localhost:5173

# CORS origins accepted by the agent server
AGENT_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Base URL the CLI uses to reach the agent server on the host
SELLERCLAW_AGENT_URL=http://127.0.0.1:8001
